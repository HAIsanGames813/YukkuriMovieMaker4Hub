<Window x:Class="YukkuriMovieMaker4Hub.IconEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:YukkuriMovieMaker4Hub"
        Title="{x:Static local:Translate.IconEditorTitle}"
        Height="600" Width="440"
        Background="{DynamicResource ThemeBrush}"
        FontFamily="{DynamicResource AppFont}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        <SolidColorBrush x:Key="ThemeBrush"   Color="#252525"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="#333333"/>
        <SolidColorBrush x:Key="ItemBrush"    Color="#444444"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#2E7D32"/>
        <SolidColorBrush x:Key="TextBrush"    Color="White"/>
        <SolidColorBrush x:Key="SubTextBrush" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#555555"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource PanelBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ItemBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Static local:Translate.IconEditorTitle}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- プレビューエリア（160×160、ドラッグ移動可能） -->
                <Border x:Name="PreviewBorder" Width="160" Height="160"
                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2" CornerRadius="4"
                        ClipToBounds="True" HorizontalAlignment="Center" Margin="0,0,0,4"
                        MouseLeftButtonDown="Preview_MouseDown"
                        MouseMove="Preview_MouseMove"
                        MouseLeftButtonUp="Preview_MouseUp"
                        MouseWheel="Preview_MouseWheel"
                        Cursor="SizeAll">
                    <Grid>
                        <Grid.Clip>
                            <RectangleGeometry Rect="0,0,160,160"/>
                        </Grid.Clip>
                        <Rectangle x:Name="BgRect" Fill="Transparent"/>
                        <Image x:Name="BgImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                        <Image x:Name="PreviewImage" Stretch="Uniform" Width="140" Height="140"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ScaleXform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="TranslateXform" X="0" Y="0"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Grid>
                </Border>
                <TextBlock Text="{x:Static local:Translate.IconDragHint}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SubTextBrush}" FontSize="10" Margin="0,0,0,12"/>

                <!-- 拡大率（ホイールで変更） -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="{x:Static local:Translate.IconScale}" Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ScaleLabel" Text="100%" Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Static local:Translate.IconWheelHint}" Foreground="{DynamicResource SubTextBrush}" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 画像選択 -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{x:Static local:Translate.IconLabel}"
                                   Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                        <TextBlock x:Name="IconSourceLabel"
                                   Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{x:Static local:Translate.SelectAnotherIcon}"
                                    Padding="12,6" Style="{StaticResource ActionButton}"
                                    Click="SelectIcon_Click" Margin="0,0,8,0"/>
                            <Button x:Name="ResetIconButton"
                                    Content="{x:Static local:Translate.ResetToExeIconShort}"
                                    Padding="12,6" Style="{StaticResource ActionButton}"
                                    Click="ResetIcon_Click" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 背景設定 -->
                <Border Background="{DynamicResource PanelBrush}" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{x:Static local:Translate.IconBgType}" FontSize="11"
                                   Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                        <WrapPanel Margin="0,0,0,8">
                            <RadioButton x:Name="BgNone" Content="{x:Static local:Translate.IconBgNone}"
                                         GroupName="BgType" IsChecked="True"
                                         Foreground="{DynamicResource TextBrush}" Margin="0,0,14,4"
                                         Checked="BgType_Changed"/>
                            <RadioButton x:Name="BgImageMode" Content="{x:Static local:Translate.IconBgImage}"
                                         GroupName="BgType"
                                         Foreground="{DynamicResource TextBrush}" Margin="0,0,14,4"
                                         Checked="BgType_Changed"/>
                            <RadioButton x:Name="BgSolid" Content="{x:Static local:Translate.IconBgSolid}"
                                         GroupName="BgType"
                                         Foreground="{DynamicResource TextBrush}" Margin="0,0,14,4"
                                         Checked="BgType_Changed"/>
                            <RadioButton x:Name="BgGradient" Content="{x:Static local:Translate.IconBgGradient}"
                                         GroupName="BgType"
                                         Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"
                                         Checked="BgType_Changed"/>
                        </WrapPanel>
                        <!-- 画像背景選択 -->
                        <StackPanel x:Name="BgImagePanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,6">
                            <TextBlock x:Name="BgImageLabel" Text="（未選択）"
                                       VerticalAlignment="Center" FontSize="10"
                                       Foreground="{DynamicResource SubTextBrush}" Margin="0,0,8,0"
                                       TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                            <Button Content="{x:Static local:Translate.Browse}" Padding="10,4"
                                    Style="{StaticResource ActionButton}" Click="SelectBgImage_Click"/>
                        </StackPanel>
                        <!-- 色選択 -->
                        <StackPanel x:Name="ColorPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,6">
                            <TextBlock Text="{x:Static local:Translate.IconBgColor1}" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,6,0"/>
                            <Button x:Name="Color1Button" Width="36" Height="24" Margin="0,0,12,0"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Click="Color1_Click" Cursor="Hand"/>
                            <TextBlock x:Name="Color2Label" Text="{x:Static local:Translate.IconBgColor2}"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource SubTextBrush}" Margin="0,0,6,0"
                                       Visibility="Collapsed"/>
                            <Button x:Name="Color2Button" Width="36" Height="24"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Click="Color2_Click" Cursor="Hand" Visibility="Collapsed"/>
                        </StackPanel>
                        <!-- グラデーション角度スライダー -->
                        <Grid x:Name="GradientAnglePanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static local:Translate.GradientAngle}"
                                       VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                            <Slider x:Name="AngleSlider" Grid.Column="1" Minimum="0" Maximum="360" Value="45"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="AngleSlider_ValueChanged" Margin="6,4,6,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="AngleBox" Grid.Column="2" Text="45"
                                     VerticalContentAlignment="Center" TextAlignment="Center"
                                     LostFocus="AngleBox_LostFocus"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ボタン -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="{x:Static local:Translate.Cancel}" Padding="16,8"
                    Style="{StaticResource ActionButton}" Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="{x:Static local:Translate.Apply}" Padding="24,8"
                    Click="Apply_Click" Foreground="White" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="White" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>