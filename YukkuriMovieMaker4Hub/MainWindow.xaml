                            <CheckBox IsChecked="{Binding CloseOnLaunch}" Content="{x:Static local:Translate.ExitHubOnYmm4Start}" Margin="0,0,0,10" Style="{StaticResource ModernCheckBox}"/>

                            <TextBlock Text="{x:Static local:Translate.PluginSettings}" FontSize="18" FontWeight="Bold" Margin="0,20,0,10" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="{x:Static local:Translate.ThemeSettings}" Margin="0,10,0,5" Foreground="{DynamicResource SubTextBrush}"/>
                            <ComboBox SelectedValue="{Binding SelectedTheme}" SelectedValuePath="Tag" Height="35">
                                <ComboBoxItem Content="{x:Static local:Translate.WindowsStandard}" Tag="{x:Static local:AppTheme.Windows}"/>
                                <ComboBoxItem Content="{x:Static local:Translate.Light}" Tag="{x:Static local:AppTheme.Light}"/>
                                <ComboBoxItem Content="{x:Static local:Translate.Dark}" Tag="{x:Static local:AppTheme.Dark}"/>
                                <ComboBoxItem Content="{x:Static local:Translate.Black}" Tag="{x:Static local:AppTheme.Black}"/>
                            </ComboBox>

                            <TextBlock Text="{x:Static local:Translate.LanguageSettings}" Margin="0,10,0,5" Foreground="{DynamicResource SubTextBrush}"/>
                            <ComboBox ItemsSource="{Binding Languages}" 
          SelectedItem="{Binding SelectedLanguage}" 
          DisplayMemberPath="Name"
          Height="35"/>
                            <TextBlock Text="{x:Static local:Translate.RestartRequired}" Margin="0,10,0,5" Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="{x:Static local:Translate.UiFont}" Margin="0,20,0,5" Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBox Text="{Binding FontSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Tag="{x:Static local:Translate.SearchFont}"/>
                            <ComboBox ItemsSource="{Binding FilteredFonts}" SelectedItem="{Binding SelectedFontItem}" Height="35">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" FontFamily="{Binding Family}" Foreground="{DynamicResource TextBrush}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="{x:Static local:Translate.MonitorEditFolder}" FontSize="18" FontWeight="Bold" Margin="0,30,0,10" Foreground="{DynamicResource TextBrush}"/>
                            <Button Content="{x:Static local:Translate.AddFolder}" Click="AddProjectDir_Click" HorizontalAlignment="Left" Padding="15,5"/>
                            <ItemsControl ItemsSource="{Binding ProjectDirectories}" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding .}" IsReadOnly="True" VerticalContentAlignment="Center" Tag="{x:Static local:Translate.FolderPath}"/>
                                            <Button Grid.Column="1" Click="OpenWatchFolder_Click" Margin="5,0,0,0" Padding="8,0" Height="35" Background="{DynamicResource ItemBrush}" BorderThickness="0" ToolTip="{x:Static local:Translate.OpenFolderTooltip}">
                                                <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{DynamicResource TextBrush}" Stretch="Uniform" Width="16" Height="16"/>
                                            </Button>
                                            <Button Grid.Column="2" Click="RemoveProjectDir_Click" Content="{x:Static local:Translate.Delete}" Margin="5,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>


                        </StackPanel>

                    </Grid>

                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>