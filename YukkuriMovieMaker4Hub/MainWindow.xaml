                                <StackPanel Orientation="Horizontal">
                                    <Path Fill="{DynamicResource TextBrush}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0" Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3Z"/>
                                    <TextBlock Text="{x:Static local:Translate.OpenLastProject}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Click="CreateNewProject_Click" IsEnabled="{Binding SelectedInstance.IsRealInstance}" Height="60" Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Fill="{DynamicResource TextBrush}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0" Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
                                    <TextBlock Text="{x:Static local:Translate.CreateNew}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <Grid Grid.Row="2" Margin="5,0,5,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <TextBox Text="{Binding ProjectSearchText, UpdateSourceTrigger=PropertyChanged}" Height="45" Tag="{x:Static local:Translate.SearchProject}"/>
                                <Path IsHitTestVisible="False" Fill="{DynamicResource SubTextBrush}" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Right" Margin="0,0,15,0" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.01,15.14C11.87,16.11 10.39,16.7 8.5,16.7A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5A4.5,4.5 0 0,0 5,9.5A4.5,4.5 0 0,0 9.5,14A4.5,4.5 0 0,0 14,9.5A4.5,4.5 0 0,0 9.5,5Z"/>
                            </Grid>

                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                <ToggleButton x:Name="ProjectFilterButton" Height="45" Width="120" Background="{DynamicResource ItemBrush}" BorderThickness="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Fill="{DynamicResource TextBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0" Data="M14,12V19.88C14.04,20.18 13.94,20.5 13.71,20.71C13.32,21.1 12.69,21.1 12.3,20.71L10.29,18.7C10.06,18.47 9.96,18.16 10,17.87V12H9.97L4.21,4.62C3.87,4.19 3.95,3.56 4.38,3.22C4.57,3.08 4.78,3 5,3V3H19V3C19.22,3 19.43,3.08 19.62,3.22C20.05,3.56 20.13,4.19 19.79,4.62L14.03,12H14Z"/>
                                        <TextBlock Text="{x:Static local:Translate.Filter}" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                    </StackPanel>
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{DynamicResource ItemBrush}" BorderThickness="1" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsChecked, ElementName=ProjectFilterButton}" StaysOpen="False" PlacementTarget="{Binding ElementName=ProjectFilterButton}" Placement="Bottom">
                                    <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource ItemBrush}" BorderThickness="1" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static local:Translate.FileFormat}" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextBrush}"/>
                                            <CheckBox Content=".ymmp" IsChecked="{Binding ShowYmmp}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                            <CheckBox Content=".ymmpx" IsChecked="{Binding ShowYmmpx}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                            <CheckBox Content=".ymmx" IsChecked="{Binding ShowYmmx}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                            <Separator Margin="0,10" Background="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="{x:Static local:Translate.Location}" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextBrush}"/>
                                            <CheckBox Content="{x:Static local:Translate.IncludeBackup}" IsChecked="{Binding ShowBackup}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                            <Separator Margin="0,10" Background="{DynamicResource TextBrush}"/>
                                            <Button Content="{x:Static local:Translate.ClearFilter}" Click="ResetProjectFilters_Click" HorizontalAlignment="Stretch" Padding="10,5" Background="Transparent" Foreground="{DynamicResource SubTextBrush}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Grid>

                        <DataGrid x:Name="ProjectGrid" Grid.Row="3" ItemsSource="{Binding FilteredProjects}" Margin="5" MouseDoubleClick="OpenProject_Click">
                            <DataGrid.Resources>
                                <Style TargetType="{x:Type ScrollBar}">
                                    <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
                                    <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
                                    <Setter Property="Width" Value="8"/>
                                    <Setter Property="Margin" Value="2,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                                    <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                                        <Track.Thumb>
                                                            <Thumb x:Name="Thumb">
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                                        <Border Background="{DynamicResource ItemBrush}" CornerRadius="4" />
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static local:Translate.FileName}" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="{x:Static local:Translate.LastUpdate}" Binding="{Binding LastWriteTime, StringFormat='yyyy/MM/dd HH:mm'}" Width="150"/>
                                <DataGridTextColumn Header="{x:Static local:Translate.Size}" Binding="{Binding DisplaySize}" ClipboardContentBinding="{Binding FileSize}" Width="120" SortMemberPath="FileSize"/>
                                <DataGridTextColumn Header="{x:Static local:Translate.Extension}" Binding="{Binding Extension}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="{x:Static local:Translate.PluginManagement}">
                    <TabItem.Resources>
                        <Style TargetType="{x:Type ScrollBar}">
                            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
                            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
                            <Setter Property="Width" Value="8"/>
                            <Setter Property="Margin" Value="2,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                                <Track.Thumb>
                                                    <Thumb x:Name="Thumb">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                                <Border Background="{DynamicResource ItemBrush}" CornerRadius="4" />
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabItem.Resources>
                    <Grid IsEnabled="{Binding SelectedInstance, Converter={StaticResource IsNotNullConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="10,5" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static local:Translate.InstanceLabel}" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextBrush}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedInstance.Name}" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/>
                            <TextBlock Text="{x:Static local:Translate.SearchLabel}" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextBrush}"/>
                            <TextBox Width="180" Text="{Binding LocalPluginSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" VerticalContentAlignment="Center" Height="28"/>
                            <Button Click="BulkToggle_Click" Content="{x:Static local:Translate.EnableDisableSelected}" Padding="10,0" Margin="0,0,6,0" Height="28" Background="{DynamicResource ItemBrush}" Foreground="{DynamicResource TextBrush}"/>
                            <Button Click="BulkDelete_Click" Content="{x:Static local:Translate.DeleteSelected}" Padding="10,0" Margin="0,0,6,0" Height="28" Background="{DynamicResource ItemBrush}" Foreground="{DynamicResource TextBrush}"/>
                            <Button Click="OpenPluginDirectoryRoot_Click" Padding="10,0" Height="28" Background="{DynamicResource ItemBrush}" Foreground="{DynamicResource TextBrush}" ToolTip="{x:Static local:Translate.OpenPluginFolder}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Fill="{DynamicResource TextBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,5,0" Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"/>
                                    <TextBlock Text="{x:Static local:Translate.FolderButton}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <ListView x:Name="LocalPluginList" Grid.Row="1" ItemsSource="{Binding LocalPlugins}" Background="Transparent" BorderThickness="0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                    <GridViewRowPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <!-- プラグイン名 -->
                                    <GridViewColumn Width="300">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.PluginName}" Click="GridViewColumnHeader_Click" Tag="DisplayName"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" Padding="5,0" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- 切替ボタン -->
                                    <GridViewColumn Width="80">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.Toggle}" Click="GridViewColumnHeader_Click" Tag="IsEnabled"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Click="TogglePlugin_Click" Width="56" Height="22" BorderThickness="0" HorizontalAlignment="Center">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Content" Value="{x:Static local:Translate.Toggle}"/>
                                                            <Setter Property="Background" Value="{DynamicResource ItemBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- 状態 -->
                                    <GridViewColumn Width="80">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.StatusColumn}" Click="GridViewColumnHeader_Click" Tag="IsEnabled"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{x:Static local:Translate.Enabled}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Text" Value="{x:Static local:Translate.Disabled}"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- 削除ボタン -->
                                    <GridViewColumn Width="80">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.Delete}" Tag="Delete"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Click="DeletePlugin_Click"
                                                        Content="{x:Static local:Translate.Delete}"
                                                        IsEnabled="{Binding IsSelectionValid}"
                                                        Background="{DynamicResource ItemBrush}"
                                                        Foreground="{DynamicResource TextBrush}"
                                                        Width="52" Height="22" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- タイプ -->
                                    <GridViewColumn Width="120">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.TypeColumn}" Click="GridViewColumnHeader_Click" Tag="Type"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayType}" Padding="5,0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- 作者名 -->
                                    <GridViewColumn Width="150">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.AuthorColumn}" Click="GridViewColumnHeader_Click" Tag="Author"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Author}" Padding="5,0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- バージョン -->
                                    <GridViewColumn Width="100">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.VersionColumn}" Click="GridViewColumnHeader_Click" Tag="Version"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Version}" Padding="5,0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- 公開日時 -->
                                    <GridViewColumn Width="100">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.PublishedAt}" Click="GridViewColumnHeader_Click" Tag="PublishedAt"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayPublishedAt}" Padding="5,0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- DL日時 -->
                                    <GridViewColumn Width="140">
                                        <GridViewColumnHeader Content="{x:Static local:Translate.DownloadedAt}" Click="GridViewColumnHeader_Click" Tag="DownloadedAt"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayDownloadedAt}" Padding="5,0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- フォルダボタン -->
                                    <GridViewColumn Width="48">
                                        <GridViewColumnHeader Content="📂" Tag="Folder"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Click="OpenLocalPluginFolder_Click" Width="36" Height="22" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" HorizontalAlignment="Center" ToolTip="{x:Static local:Translate.OpenFolderTooltip}">
                                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{DynamicResource TextBrush}" Stretch="Uniform" Width="12"/>
                                                </Button>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>


                <TabItem Header="{x:Static local:Translate.PluginPortal}">
                    <TabItem.Resources>
                        <Style TargetType="{x:Type ScrollBar}">
                            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
                            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
                            <Setter Property="Width" Value="8"/>
                            <Setter Property="Margin" Value="2,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                                <Track.Thumb>
                                                    <Thumb x:Name="Thumb">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                                <Border Background="{DynamicResource ItemBrush}" CornerRadius="4" />
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabItem.Resources>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="10,5">
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,5,20,5">
                                    <TextBlock Text="{x:Static local:Translate.SearchPlugins}" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBox Text="{Binding OnlinePluginSearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="28" VerticalContentAlignment="Center" Tag="{x:Static local:Translate.SearchPlugins}" />
                                    <Grid Margin="5,0,0,0">
                                        <ToggleButton x:Name="FilterButton" Content="" FontFamily="Segoe MDL2 Assets" Width="32" Height="28">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton">
                                                    <Setter Property="Background" Value="{DynamicResource ItemBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#555555"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background" Value="#666666"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                        <Popup IsOpen="{Binding IsChecked, ElementName=FilterButton}" StaysOpen="False" PlacementTarget="{Binding ElementName=FilterButton}" Placement="Bottom">
                                            <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource ItemBrush}" BorderThickness="1" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="200"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 左列 -->
                                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                        <TextBlock Text="{x:Static local:Translate.TypeFilter}" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextBrush}"/>
                                                        <ItemsControl ItemsSource="{Binding PluginTypeFilters}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Foreground="{DynamicResource TextBrush}" Margin="0,2"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Separator Margin="0,10" Background="{DynamicResource TextBrush}"/>
                                                        <Button Content="{x:Static local:Translate.CheckAll}" Click="AllCheck_Click" Margin="0,2"/>
                                                        <Button Content="{x:Static local:Translate.UncheckAll}" Click="NoneCheck_Click" Margin="0,2"/>
                                                    </StackPanel>

                                                    <!-- 右列 -->
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{x:Static local:Translate.DownloadStatus}" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource TextBrush}"/>
                                                        <RadioButton x:Name="FilterAll" Content="{x:Static local:Translate.All}" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,2" Checked="DownloadFilter_Changed" GroupName="DownloadFilter"/>
                                                        <RadioButton x:Name="FilterDownloaded" Content="{x:Static local:Translate.Downloaded}" Foreground="{DynamicResource TextBrush}" Margin="0,2" Checked="DownloadFilter_Changed" GroupName="DownloadFilter"/>
                                                        <RadioButton x:Name="FilterNotDownloaded" Content="{x:Static local:Translate.NotDownloaded}" Foreground="{DynamicResource TextBrush}" Margin="0,2" Checked="DownloadFilter_Changed" GroupName="DownloadFilter"/>
                                                        <RadioButton x:Name="FilterHasUpdate" Content="{x:Static local:Translate.HasUpdate}" Foreground="{DynamicResource TextBrush}" Margin="0,2" Checked="DownloadFilter_Changed" GroupName="DownloadFilter"/>

                                                        <Separator Margin="0,10" Background="{DynamicResource TextBrush}"/>
