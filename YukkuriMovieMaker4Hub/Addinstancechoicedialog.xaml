<Window x:Class="YukkuriMovieMaker4Hub.AddInstanceChoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:YukkuriMovieMaker4Hub"
        Title="{x:Static local:Translate.AddInstanceTitle}" Height="308" Width="440"
        Background="{DynamicResource ThemeBrush}"
        FontFamily="{DynamicResource AppFont}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <!-- テーマリソース（MainWindowと同じデフォルト値。ApplyThemeで上書きされる） -->
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        <SolidColorBrush x:Key="ThemeBrush"   Color="#252525"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="#333333"/>
        <SolidColorBrush x:Key="ItemBrush"    Color="#444444"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#2E7D32"/>
        <SolidColorBrush x:Key="TextBrush"    Color="White"/>
        <SolidColorBrush x:Key="SubTextBrush" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#555555"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Static local:Translate.SelectAddMethod}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 新規ダウンロード -->
            <Button Grid.Column="0" Click="NewDownload_Click" Cursor="Hand" Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Margin="10,10" HorizontalAlignment="Center">
                    <!-- ダウンロードアイコン（下矢印＋トレイ） -->
                    <Viewbox Width="36" Height="36" Margin="0,0,0,10">
                        <Path Fill="{DynamicResource TextBrush}" Stretch="Uniform"
                              Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"/>
                    </Viewbox>
                    <TextBlock Text="{x:Static local:Translate.NewDownload}"
                               FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Static local:Translate.NewDownloadDesc}"
                               Foreground="{DynamicResource SubTextBrush}"
                               FontSize="10" HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>

            <!-- 既存を追加 -->
            <Button Grid.Column="2" Click="AddExisting_Click" Cursor="Hand" Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1565C0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Margin="10,10" HorizontalAlignment="Center">
                    <!-- フォルダアイコン -->
                    <Viewbox Width="36" Height="36" Margin="0,0,0,10">
                        <Path Fill="{DynamicResource TextBrush}" Stretch="Uniform"
                              Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"/>
                    </Viewbox>
                    <TextBlock Text="{x:Static local:Translate.AddExisting}"
                               FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Static local:Translate.AddExistingDesc}"
                               Foreground="{DynamicResource SubTextBrush}"
                               FontSize="10" HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- キャンセル -->
        <Button Grid.Row="2" Content="{x:Static local:Translate.Cancel}" Click="Cancel_Click"
                Margin="0,16,0,0" Padding="20,8" HorizontalAlignment="Right" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
