<Window x:Class="YukkuriMovieMaker4Hub.InstanceSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:YukkuriMovieMaker4Hub"
        Title="{x:Static local:Translate.InstanceSetupTitle}" Height="560" Width="480"
        Background="{DynamicResource ThemeBrush}"
        FontFamily="{DynamicResource AppFont}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <!-- テーマリソース（MainWindowと同じデフォルト値。ApplyThemeで上書きされる） -->
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        <SolidColorBrush x:Key="ThemeBrush"   Color="#252525"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="#333333"/>
        <SolidColorBrush x:Key="ItemBrush"    Color="#444444"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#2E7D32"/>
        <SolidColorBrush x:Key="TextBrush"    Color="White"/>
        <SolidColorBrush x:Key="SubTextBrush" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#555555"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource PanelBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource ItemBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditionButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource ItemBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="{x:Static local:Translate.InstanceSetupTitle}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- エディション選択（新規DL時のみ） -->
                <StackPanel x:Name="EditionPanel" Visibility="Collapsed" Margin="0,0,0,18">
                    <TextBlock Text="{x:Static local:Translate.Edition}"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="NormalEdition" Grid.Column="0"
                                     Style="{StaticResource EditionButton}" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{x:Static local:Translate.NormalEdition}"
                                           FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock Text="{x:Static local:Translate.NormalEditionDesc}"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           FontSize="10" TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="LiteEdition" Grid.Column="2"
                                     Style="{StaticResource EditionButton}">
                            <StackPanel>
                                <TextBlock Text="{x:Static local:Translate.LiteEdition}"
                                           FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock Text="{x:Static local:Translate.LiteEditionDesc}"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           FontSize="10" TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                </StackPanel>

                <!-- アイコン -->
                <TextBlock Text="{x:Static local:Translate.IconLabel}"
                           Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- アイコンプレビュー（小） -->
                    <Border Width="64" Height="64" CornerRadius="4" ClipToBounds="True"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Rectangle x:Name="IconPreviewBg" Fill="Transparent"/>
                            <Image x:Name="IconPreview" Stretch="Uniform" Margin="4"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Button Content="{x:Static local:Translate.OpenIconEditor}"
                                Padding="12,6" Style="{StaticResource ActionButton}"
                                Click="OpenIconEditor_Click" HorizontalAlignment="Left"
                                x:Name="IconEditorButton" IsEnabled="False"/>
                    </StackPanel>
                </Grid>

                <!-- インスタンス名 -->
                <TextBlock Text="{x:Static local:Translate.InstanceNameLabel}"
                           Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,6"/>
                <TextBox x:Name="NameTextBox" Margin="0,0,0,18" Text="YukkuriMovieMaker4"/>

                <!-- インストール先（新規DL時のみ） -->
                <StackPanel x:Name="InstallFolderPanel" Visibility="Collapsed">
                    <TextBlock Text="{x:Static local:Translate.InstallFolder}"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InstallFolderTextBox" IsReadOnly="True"/>
                        <Button Grid.Column="2" Content="{x:Static local:Translate.Browse}" Padding="12,6"
                                Style="{StaticResource ActionButton}"
                                Click="BrowseFolder_Click"/>
                    </Grid>
                    <TextBlock Text="{x:Static local:Translate.InstallFolderNote}"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="10"/>
                </StackPanel>

                <!-- ダウンロード進捗 -->
                <StackPanel x:Name="DownloadProgressPanel" Visibility="Collapsed" Margin="0,16,0,0">
                    <TextBlock x:Name="DownloadStatusText" Text="{x:Static local:Translate.Preparing}"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                    <ProgressBar x:Name="DownloadProgressBar" Height="6"
                                 Background="{DynamicResource PanelBrush}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 BorderThickness="0" Minimum="0" Maximum="100"/>
                    <TextBlock x:Name="DownloadSizeText"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="10" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ボタン -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="CancelButton" Content="{x:Static local:Translate.Cancel}" Padding="16,8"
                    Style="{StaticResource ActionButton}" Click="Cancel_Click"/>
            <Button x:Name="OkButton" Grid.Column="2"
                    Content="{x:Static local:Translate.Add}"
                    Click="Ok_Click" Padding="28,8" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>